{
  "name": "sovereign-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Sovereign desktop shell — a minimal Tauri app that loads your self-hosted Sovereign instance",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "dev:web": "vite",
    "build:web": "tsc && vite build",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-http": "^2.5.5",
    "@tauri-apps/plugin-store": "^2.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@tauri-apps/cli": "^2.9.6",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.14.0",
    "prettier": "^3.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.2"
}
